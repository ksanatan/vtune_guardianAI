# ============================================
# VTune GuardianAI - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# GitHub Copilot / GitHub Models (FREE with Copilot subscription)
# Create a PAT at: https://github.com/settings/tokens
# Primary: o3 (best reasoning model). Fallback: o3-mini (if rate-limited).
# Other models: o4-mini, gpt-4o, gpt-4o-mini, gpt-4.1
GITHUB_TOKEN=
GITHUB_MODEL=o3
GITHUB_FALLBACK_MODEL=o3-mini
# GITHUB_BASE_URL=https://models.inference.ai.azure.com

# Static Analysis Tools (auto-detected if on PATH)
CPPCHECK_PATH=cppcheck
CLANG_TIDY_PATH=clang-tidy

# Guardian Settings
GUARDIAN_SEVERITY_THRESHOLD=warning
GUARDIAN_MAX_FILES=50
GUARDIAN_REPORT_FORMAT=terminal
