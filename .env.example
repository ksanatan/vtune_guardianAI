# ============================================
# VTune GuardianAI - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values.
# Documentation: see README.md → Configuration Reference

# ── LLM Provider ──
# Choose: "bedrock" (AWS Bedrock / Claude — recommended) or "github" (GitHub Models)
LLM_PROVIDER=bedrock

# ── AWS Bedrock (Claude via SAI/AIDE) — ITS APPROVED ──
# Generate token at: https://tokengen.aide.infra-host.com/
# Token TTL: ~167 hours (~7 days). Regenerate when expired.
# The token starts with "ABSK..." — paste the full value below.
AWS_BEARER_TOKEN_BEDROCK=
AWS_REGION=us-east-2
BEDROCK_MODEL=global.anthropic.claude-sonnet-4-20250514-v1:0
BEDROCK_FALLBACK_MODEL=us.anthropic.claude-3-5-haiku-20241022-v1:0

# ── GitHub Models (alternative provider) ──
# Create a PAT at: https://github.com/settings/tokens (scope: copilot)
# Primary: o3 (best reasoning). Fallback: o3-mini (if rate-limited).
# Model chain (optional): comma-separated list for cascading fallback.
GITHUB_TOKEN=
GITHUB_MODEL=o3
GITHUB_FALLBACK_MODEL=o3-mini
# GITHUB_MODEL_CHAIN=o3,o3-mini,o4-mini,gpt-4.1-mini
# GITHUB_BASE_URL=https://models.inference.ai.azure.com

# ── Static Analysis Tools (optional, auto-detected if on PATH) ──
CPPCHECK_PATH=cppcheck
CLANG_TIDY_PATH=clang-tidy

# ── Guardian Settings ──
GUARDIAN_SEVERITY_THRESHOLD=warning
GUARDIAN_MAX_FILES=50
GUARDIAN_REPORT_FORMAT=terminal
